# TON testnet wallet (24-word mnemonic) — used by blueprint deploy scripts
WALLET_MNEMONIC=word1 word2 word3 ... word24
# Tonkeeper W5 → use v5r1 (blueprint / @ton/ton Wallet V5 R1)
WALLET_VERSION=v5r1

# Testnet endpoint (get a free key at https://t.me/toncenter)
ENDPOINT_URL=https://testnet.toncenter.com/api/v2/jsonRPC
ENDPOINT_TYPE=testnet
ENDPOINT_VERSION=v2
ENDPOINT_KEY=
