{
  "name": "@testdex/web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "predev": "node scripts/generate-manifest.mjs",
    "dev": "npx vite",
    "prebuild": "node scripts/generate-manifest.mjs",
    "build": "tsc -b && npx vite build",
    "build:pages": "node scripts/generate-manifest.mjs && tsc -b && npx vite build",
    "preview": "npx vite preview",
    "preview:pages": "VITE_BASE_PATH=/testdex/ VITE_SITE_URL=https://mrandreano.github.io/testdex npm run build:pages && npx vite preview --base /testdex/"
  },
  "dependencies": {
    "@ston-fi/sdk": "^2.7.0",
    "@ton/core": "^0.62.0",
    "@ton/crypto": "^3.3.0",
    "@ton/ton": "^15.2.1",
    "@tonconnect/ui-react": "^2.4.2",
    "buffer": "^6.0.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.7.2",
    "vite": "^6.0.3"
  }
}
